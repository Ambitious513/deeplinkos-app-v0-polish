NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Never expose this in browser code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used to hash IP addresses before writing analytics rows.
IP_HASH_SALT=replace-with-a-long-random-string

# Optional email provider for auth/product email flows.
RESEND_API_KEY=your-resend-api-key
SUPPORT_EMAIL=support@deeplinkos.com
